# Life Dashboard Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== ENVIRONMENT =====
# Set to 'production' for production deployments
ENVIRONMENT=development

# ===== GROQ API CONFIGURATION =====
# Get your API key from https://console.groq.com
# This is required for AI-powered insights generation
GROQ_API_KEY=your-groq-api-key-here

# ===== JWT SECRET KEY =====
# Used for signing JWT tokens during authentication
# Generate a strong random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Change this in production!
SECRET_KEY=your-super-secret-key-change-this-in-production

# ===== DATABASE =====
# For development: SQLite (default)
# DATABASE_URL=sqlite:///./life_dashboard.db
# For production: PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/lifedashboard
DATABASE_URL=sqlite:///./life_dashboard.db

# ===== LOGGING =====
# Log directory for app and error logs
LOG_DIR=logs

# ===== CORS (Production Only) =====
# Comma-separated list of allowed origins
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# ===== DEPLOYMENT =====
# Set to true for Railway/Cloud deployment
CLOUD_DEPLOYMENT=false
